# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# OpenRouter key used for secondary AI models and key rotation
OPENROUTER_API_KEY=""

# Groq API key used for quick model responses
GROQ_API_KEY=""

# Stripe secret key for teacher record keeping or payments
STRIPE_SECRET_KEY=""

# Cloudinary credentials for professor avatar uploading
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_UPLOAD_PRESET=""
CLOUDINARY_UPLOAD_URL=""
