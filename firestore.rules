rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Catch-All Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Auth & Identity Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && isEmailVerified() && (
        request.auth.token.email.lower() == "dalind1990@gmail.com" ||
        request.auth.token.email.lower() == "dalinadjib169@gmail.com" ||
        request.auth.token.email.lower() == "dalinadjib1990@gmail.com"
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Settings Collection Rules
    match /settings/{settingsId} {
      // Anyone can read general settings (so the client can fetch the welcome message/profile pic/active features)
      allow read: if true;
      
      // Only validated Admin accounts can write settings
      allow write: if isAdmin() && isValidId(settingsId);
    }

    // Sessions Collection Rules
    match /sessions/{sessionId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      
      allow create: if isSignedIn() && 
                    isValidId(sessionId) && 
                    request.resource.data.userId == request.auth.uid &&
                    request.resource.data.createdAt is string;

      allow update: if isSignedIn() && 
                    resource.data.userId == request.auth.uid && 
                    request.resource.data.userId == request.auth.uid;
                    
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());

      // Nested Messages Collection Rules
      match /messages/{messageId} {
        allow read: if isSignedIn() && (
          get(/databases/$(database)/documents/sessions/$(sessionId)).data.userId == request.auth.uid ||
          isAdmin()
        );

        allow create: if isSignedIn() && 
                      isValidId(messageId) && (
                        get(/databases/$(database)/documents/sessions/$(sessionId)).data.userId == request.auth.uid ||
                        isAdmin()
                      ) &&
                      request.resource.data.sender in ['user', 'assistant'] &&
                      request.resource.data.text is string &&
                      request.resource.data.text.size() <= 50000;

        allow update, delete: if isAdmin();
      }
    }
  }
}
